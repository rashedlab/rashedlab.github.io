doi = {10.1145/3665026.3665049},
abstract = {Stroke lesion segmentation in 3D MRI represents a significant challenge due to the brain’s intricate anatomy and the variable appearance of lesions. This study proposes a novel Neuro-TransUNet framework, blending SwinUNETR and U-Net architectures with advanced feature fusion and segmentation synthesis techniques. The designed framework is significantly improved by data resampling, skull stripping, and bias correction, as reflected in computed dice scores. This study also demonstrates the effect of pre-processing steps on segmentation performance, comprehensively comparing results with existing benchmarks and highlighting the framework’s potential to advance stroke diagnosis and treatment planning.},
booktitle = {Proceedings of the 2024 9th International Conference on Multimedia and Image Processing},
pages = {152–156},
numpages = {5},
keywords = {Image segmentation, MRI, Neuro-TransUNet, deep learning, stroke, transformer},
location = {Osaka, Japan},
series = {ICMIP '24}
}