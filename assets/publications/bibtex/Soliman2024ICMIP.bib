doi = {10.1145/3665026.3665045},
abstract = {Ischemic brain stroke occurs when a thrombus blocks a brain artery leading to a regional damage of brain due to lack of normal blood flow. Identification and diagnosis of stroke requires quick processing of medical image such as MRI. Segmentation of brain strokes is known to be a challenging task due to variability in the size and location of the stroke. In this paper, we examine a Transformer-based deep learning architecture, called Dual Attention-guided efficient Transformer (DAE-Former) for several stroke benchmarks. For efficient evaluation, several loss function combinations were examined along with dipping the original architecture, resulting in the Enhanced DAE-Former. The proposed modification leads to marginal improvement in the segmentation accuracy, especially evident in the results obtained from the ATLAS v2.0 dataset. In contrast, the performance improvements were not as pronounced with the smaller ISLES22 dataset. Both the original and Enhanced DAE-Former architectures performed similarly on this dataset. This outcome suggests that the enhanced model are more apparent in larger datasets, where the increased complexity of the architecture can be fully leveraged.},
booktitle = {Proceedings of the 2024 9th International Conference on Multimedia and Image Processing},
pages = {127–131},
numpages = {5},
keywords = {Transformers, deep learning., medical imaging, stroke segmentation},
location = {Osaka, Japan},
series = {ICMIP '24}
}